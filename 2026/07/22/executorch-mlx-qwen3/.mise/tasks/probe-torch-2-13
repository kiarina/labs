#!/usr/bin/env bash
#MISE description="Reproduce the ExecuTorch 1.3.1 wheel incompatibility with PyTorch 2.13"
set -euo pipefail

probe_dir="output/torch-2.13-probe"
mkdir -p output
uv venv --clear --python 3.13 "$probe_dir"
uv pip install --python "$probe_dir/bin/python" \
  "executorch==1.3.1" "torch==2.13.0"
"$probe_dir/bin/python" -c \
  'from executorch.extension.pybindings import portable_lib; print(portable_lib.__file__)'
